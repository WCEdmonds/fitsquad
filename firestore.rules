/**
 * @fileoverview Firestore Security Rules for FitSquad.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for personal data (accounts, soldier data, exercise progress).
 * Team data and workout plans are accessible to team members.
 * Commanders can manage teams and view their data.
 *
 * Data Structure:
 * - /accounts/{accountId}: User account information.
 * - /accounts/{accountId}/managedTeams/{teamId}: Teams managed by a commander.
 * - /teams/{teamId}: Team information.
 * - /teams/{teamId}/members/{userId}: Team membership.
 * - /accounts/{accountId}/soldierData/{soldierDataId}: Fitness data for soldiers.
 * - /teams/{teamId}/workoutPlans/{workoutPlanId}: Workout plans for teams.
 * - /teams/{teamId}/workoutPlans/{workoutPlanId}/exercises/{exerciseId}: Exercises for workout plans.
 * - /accounts/{accountId}/exercisesProgress/{progressId}: Soldier progress on exercises.
 *
 * Key Security Decisions:
 * - Users can only access their own account and soldier data.
 * - Team membership is required to access team-related data.
 * - Commanders have elevated privileges to manage teams.
 *
 * Denormalization for Authorization:
 * - Team membership is managed via the `/teams/{teamId}/members/{userId}` subcollection.
 * - Commander's managed teams are stored in `/accounts/{commanderId}/managedTeams/{teamId}`.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user account information.
     */
    match /accounts/{accountId} {
      allow get: if isOwner(accountId);
      allow list: if false;
      allow create: if isSelfCreate(accountId);
      allow update: if isExistingOwner(accountId) && isAccountIdNotChanged();
      allow delete: if isExistingOwner(accountId);

      /**
       * @description Controls access to a commander's list of managed teams.
       */
      match /managedTeams/{teamId} {
        allow read, write: if isOwner(accountId) && isCommander(accountId);
      }
    }

    /**
     * @description Controls access to team information.
     */
    match /teams/{teamId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false; // TODO: Add team membership check
    }

    /**
     * @description Controls access to team membership information.
     */
    match /teams/{teamId}/members/{userId} {
        allow get, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isOwner(userId);
    }

    /**
     * @description Controls access to soldier fitness data.
     */
    match /accounts/{accountId}/soldierData/{soldierDataId} {
      allow get: if isOwner(accountId);
      allow list: if isOwner(accountId);
      allow create: if isSignedIn() && request.resource.data.accountId == accountId;
      allow update: if isExistingOwner(accountId) && resource.data.accountId == accountId;
      allow delete: if isExistingOwner(accountId);
    }

    /**
     * @description Controls access to workout plans for teams.
     */
    match /teams/{teamId}/workoutPlans/{workoutPlanId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.teamId == teamId;
      allow update, delete: if false; // TODO: Add team membership check and validate teamId is immutable
    }

    /**
     * @description Controls access to exercises within workout plans.
     */
    match /teams/{teamId}/workoutPlans/{workoutPlanId}/exercises/{exerciseId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.workoutPlanId == workoutPlanId;
      allow update, delete: if false; // TODO: Add team membership check and validate workoutPlanId is immutable
    }

    /**
     * @description Controls access to exercise progress data for soldiers.
     */
    match /accounts/{accountId}/exercisesProgress/{progressId} {
      allow get: if isOwner(accountId);
      allow list: if isOwner(accountId);
      allow create: if isSignedIn() && request.resource.data.accountId == accountId;
      allow update: if isExistingOwner(accountId) && resource.data.accountId == accountId;
      allow delete: if isExistingOwner(accountId);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isSelfCreate(accountId) {
        return isSignedIn() && request.auth.uid == accountId && request.resource.data.id == accountId;
    }

    function isAccountIdNotChanged() {
        return request.resource.data.id == resource.data.id;
    }

    function isCommander(accountId) {
      return get(/databases/$(database)/documents/accounts/$(accountId)).data.accountType == 'Commander';
    }
  }
}
