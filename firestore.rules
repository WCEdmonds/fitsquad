/**
 * @fileoverview Firestore Security Rules for FitSquad.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for personal data (accounts, soldier data, exercise progress).
 * Team data and workout plans are accessible to team members.
 * Commanders can manage teams and view their data.
 * Admins have global read and team management capabilities.
 *
 * Data Structure:
 * - /accounts/{accountId}: User account information.
 * - /accounts/{accountId}/managedTeams/{teamId}: Teams managed by a commander.
 * - /teams/{teamId}: Team information.
 * - /teams/{teamId}/members/{userId}: Team membership.
 * - /accounts/{accountId}/soldierData/{soldierDataId}: Fitness data for soldiers.
 * - /teams/{teamId}/workoutPlans/{workoutPlanId}: Workout plans for teams.
 * - /teams/{teamId}/workoutPlans/{workoutPlanId}/exercises/{exerciseId}: Exercises for workout plans.
 * - /accounts/{accountId}/exercisesProgress/{progressId}: Soldier progress on exercises.
 *
 * Key Security Decisions:
 * - Users can only access their own account and soldier data.
 * - Team membership is required to access team-related data.
 * - Commanders have elevated privileges to manage teams.
 * - Admins can read all user and team data and manage any team.
 *
 * Denormalization for Authorization:
 * - Team membership is managed via the `/teams/{teamId}/members/{userId}` subcollection.
 * - Commander's managed teams are stored in `/accounts/{commanderId}/managedTeams/{teamId}`.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user account information.
     * Supports both claimed accounts (owned by Firebase users) and unclaimed profiles.
     */
    match /accounts/{accountId} {
      allow get: if isOwner(accountId) || isAdmin() || isUnclaimedProfile();
      allow list: if isAdmin() || isSignedIn(); // Allow listing for team management
      allow create: if isSelfCreate(accountId) || canCreateUnclaimedProfile();
      allow update: if (isExistingOwner(accountId) && isAccountIdNotChanged()) || isAdmin() || canClaimProfile();
      allow delete: if isAdmin() || isClaimingProfile();

      /**
       * @description Controls access to a commander's list of managed teams.
       */
      match /managedTeams/{teamId} {
        allow read, write: if isOwner(accountId) && isCommander(accountId);
      }
      
      /**
       * @description Controls access to exercise progress data for soldiers.
       */
      match /exercisesProgress/{progressId} {
        allow get: if isOwner(accountId);
        allow list: if isOwner(accountId);
        allow create: if isOwner(accountId) && request.resource.data.accountId == accountId;
        allow update: if isOwner(accountId) && resource.data.accountId == accountId;
        allow delete: if isOwner(accountId);
      }
    }

    /**
     * @description Controls access to team information.
     */
    match /teams/{teamId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin(); // Only admins can update/delete a whole team
    }

    /**
     * @description Controls access to team membership information.
     */
    match /teams/{teamId}/members/{userId} {
        allow get, list: if true;
        allow create: if isSignedIn() || isAdmin(); // Users can join, admins can add
        allow update, delete: if isOwner(userId) || isAdmin(); // Users can leave, admins can remove
    }

    /**
     * @description Controls access to soldier fitness data.
     * Allows supervisors/commanders to add data to unclaimed profiles.
     */
    match /accounts/{accountId}/soldierData/{soldierDataId} {
      allow get: if isOwner(accountId) || isAdmin() || canManageUnclaimedProfile(accountId);
      allow list: if isOwner(accountId) || isAdmin() || canManageUnclaimedProfile(accountId);
      allow create: if (isSignedIn() && request.resource.data.accountId == accountId) || canManageUnclaimedProfile(accountId);
      allow update: if (isExistingOwner(accountId) && resource.data.accountId == accountId) || canManageUnclaimedProfile(accountId);
      allow delete: if isExistingOwner(accountId) || canManageUnclaimedProfile(accountId);
    }

    /**
     * @description Controls access to workout plans for teams.
     */
    match /teams/{teamId}/workoutPlans/{workoutPlanId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.teamId == teamId;
      allow update, delete: if false; // TODO: Add team membership check and validate teamId is immutable
    }

    /**
     * @description Controls access to exercises within workout plans.
     */
    match /teams/{teamId}/workoutPlans/{workoutPlanId}/exercises/{exerciseId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.workoutPlanId == workoutPlanId;
      allow update, delete: if false; // TODO: Add team membership check and validate workoutPlanId is immutable
    }

    /**
     * @description Controls access to the main editable team plan.
     * Supervisors and Admins can edit, everyone can read.
     */
    match /teams/{teamId}/mainPlan/{planId} {
      allow read: if true; // Everyone can view the team plan
      allow create, update: if isSignedIn() && (isSupervisorOrAdmin()); // Only Supervisors and Admins can edit
      allow delete: if isAdmin(); // Only Admins can delete
    }

    /**
     * @description Controls access to custom workout templates for teams.
     * Supervisors and Admins can create/edit/delete, everyone can read.
     */
    match /teams/{teamId}/customTemplates/{templateId} {
      allow read: if true; // Everyone can view templates
      allow create: if isSignedIn() && isSupervisorOrAdmin(); // Only Supervisors and Admins can create
      allow update, delete: if isSignedIn() && isSupervisorOrAdmin(); // Only Supervisors and Admins can edit/delete
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isSelfCreate(accountId) {
        return isSignedIn() && request.auth.uid == accountId && request.resource.data.id == accountId;
    }

    function isAccountIdNotChanged() {
        return request.resource.data.id == resource.data.id;
    }

    function isCommander(accountId) {
      return get(/databases/$(database)/documents/accounts/$(accountId)).data.accountType == 'Commander';
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.accountType == 'Admin';
    }

    function isSupervisorOrCommander() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.accountType == 'Supervisor' ||
        get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.accountType == 'Commander'
      );
    }

    function isSupervisorOrAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.accountType == 'Supervisor' ||
        get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.accountType == 'Admin'
      );
    }

    function isUnclaimedProfile() {
      return resource != null && resource.data.claimed == false;
    }

    function canCreateUnclaimedProfile() {
      return isSignedIn() &&
             isSupervisorOrCommander() &&
             request.resource.data.claimed == false &&
             request.resource.data.createdBy == request.auth.uid;
    }

    function canManageUnclaimedProfile(accountId) {
      let account = get(/databases/$(database)/documents/accounts/$(accountId)).data;
      return isSignedIn() &&
             account.claimed == false &&
             (account.createdBy == request.auth.uid || isAdmin());
    }

    function canClaimProfile() {
      return isSignedIn() &&
             resource != null &&
             resource.data.claimed == false &&
             request.resource.data.claimed == true &&
             request.auth.uid == request.resource.data.id;
    }

    function isClaimingProfile() {
      return resource != null && resource.data.claimed == false;
    }
  }
}

    